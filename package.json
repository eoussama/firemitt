{
  "name": "@eoussama/firemitt",
  "type": "module",
  "version": "0.1.6",
  "packageManager": "pnpm@11.9.0",
  "description": "Yes, fireguards are hot, but not enough to burn. Intermediate package that facilitates working with Fireguard.",
  "author": {
    "name": "eoussama",
    "url": "https://ouss.es",
    "email": "oussama.essamadi@gmail.com"
  },
  "license": "Apache-2.0",
  "homepage": "https://ouss.es/firemitt",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/eoussama/firemitt.git"
  },
  "bugs": {
    "url": "https://github.com/eoussama/firemitt/issues"
  },
  "keywords": [
    "auth",
    "firebase",
    "fireguard",
    "firebase-auth"
  ],
  "main": "firemitt.es.js",
  "files": [
    "LICENSE",
    "README.md",
    "dist"
  ],
  "scripts": {
    "prepublishOnly": "pnpm build",
    "dev": "vite",
    "test": "pnpm exec jest",
    "coverage": "pnpm exec jest --coverage",
    "preview": "vite preview",
    "clean": "rm -rf dist pkg",
    "build": "tsc && vite build",
    "lint": "dx lint",
    "lint:fix": "dx lint --fix",
    "package": "./scripts/package.sh",
    "doc": "pnpm exec typedoc && cp assets/favicon.ico doc/",
    "prod": "pnpm audit && pnpm lint && pnpm build && pnpm test && pnpm coverage"
  },
  "jest": {
    "coverageProvider": "v8",
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": 100
      }
    }
  },
  "dependencies": {
    "@eoussama/core": "^0.0.4"
  },
  "devDependencies": {
    "@eoussama/dx": "^0.0.4",
    "jest": "^30.4.2",
    "typedoc": "^0.28.19",
    "typedoc-material-theme": "^1.4.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-dts": "^5.0.3"
  }
}
